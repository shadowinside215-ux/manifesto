# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EMAIL_USER & EMAIL_PASS: Used for sending contact form emails via Gmail SMTP.
# For Gmail, you MUST use an "App Password" (Google Account -> Security -> 2-Step Verification -> App Passwords).
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
CONTACT_RECEIVER_EMAIL="manifesto.interiors@gmail.com"

# Cloudinary Configuration
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
