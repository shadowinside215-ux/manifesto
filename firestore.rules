rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - email: string (required, email format) - User's email
    //   - role: string (required, enum: ['admin', 'user']) - User's role
    //   - createdAt: timestamp (optional) - When the user was created
    //
    // Collection: photos
    // Document ID: {photoId}
    // Fields:
    //   - id: string (optional) - Photo ID
    //   - url: string (required, url format) - Cloudinary URL
    //   - publicId: string (required) - Cloudinary public ID
    //   - title: string (optional) - Photo title
    //   - category: string (optional) - Photo category
    //   - uploadedBy: string (required) - UID of the uploader
    //   - createdAt: timestamp (required) - Upload timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null;
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['url', 'publicId', 'title', 'category', 'uploadedBy', 'createdAt']) &&
             data.url is string && data.url.size() < 1024 &&
             data.publicId is string && data.publicId.size() < 256 &&
             data.title is string && data.title.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.uploadedBy == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if false;
    }

    match /photos/{photoId} {
      allow read: if true; // Publicly viewable gallery
      allow create: if isAdmin() && isValidPhoto(request.resource.data);
      allow update: if isAdmin() 
                    && (isValidPhoto(request.resource.data) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title']) && request.resource.data.title is string));
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
