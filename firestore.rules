rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - email: string (required, email format) - User's email
    //   - role: string (required, enum: ['admin', 'user']) - User's role
    //   - createdAt: timestamp (optional) - When the user was created
    //
    // Collection: photos
    // Document ID: {photoId}
    // Fields:
    //   - id: string (optional) - Photo ID
    //   - url: string (required, url format) - Cloudinary URL
    //   - publicId: string (required) - Cloudinary public ID
    //   - title: string (optional) - Photo title
    //   - category: string (optional) - Photo category
    //   - uploadedBy: string (required) - UID of the uploader
    //   - createdAt: timestamp (required) - Upload timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dragonballsam86@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['url', 'publicId', 'uploadedBy', 'createdAt']) &&
             data.url is string &&
             data.publicId is string &&
             data.uploadedBy is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /photos/{photoId} {
      allow read: if true; // Publicly viewable gallery
      allow create: if isAdmin() && isValidPhoto(request.resource.data);
      allow update: if isAdmin() && isValidPhoto(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
